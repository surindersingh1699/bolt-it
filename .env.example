# Copy to .env and fill in. The service runs without OPENAI_API_KEY using a
# stub LLM (returns canned plans from a tag-scoring heuristic) so you can
# demo the full graph with zero external dependencies.

# Database
DATABASE_URL=postgresql+asyncpg://it_copilot:it_copilot@localhost:5432/it_copilot
DATABASE_URL_SYNC=postgresql+psycopg://it_copilot:it_copilot@localhost:5432/it_copilot

# LLM (optional — without these the stub LLM is used)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VERIFIER_MODEL=gpt-4o
EMBED_MODEL=text-embedding-3-small

# Observability (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=it-copilot
LANGCHAIN_TRACING_V2=false

# Service
LOG_LEVEL=INFO
